{
  "name": "conductor-api",
  "version": "1.0.0",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmit && esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --external:better-sqlite3",
    "start": "node dist/index.js",
    "seed": "tsx src/seed.ts",
    "keygen": "tsx src/keygen.ts"
  },
  "dependencies": {
    "fastify": "^4.28.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "better-sqlite3": "^9.6.0",
    "drizzle-orm": "^0.30.10",
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.4.0",
    "nanoid": "^5.0.7",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^20.14.2",
    "drizzle-kit": "^0.21.4",
    "esbuild": "^0.21.5",
    "tsx": "^4.15.2",
    "typescript": "^5.5.2"
  }
}
